{
  "name": "verimus-solution",
  "version": "1.0.0",
  "description": "Implementation of Verimus over Verimus",
  "main": "index.js",
  "scripts": {
    "start": "tsx index.ts",
    "keygen": "tsx generate_keys/GenerateKeys.ts",
    "build:ui": "npm --prefix ui run build",
    "watch:ui": "npm --prefix ui run watch",
    "start:node": "tsx index.ts",
    "watch:node": "nodemon -x tsx -e ts --ignore data/ --ignore storage/ index.ts",
    "test": "tsx --test --test-timeout=300000 \"{apis_server,bundler,crypto_utils,ledger,logger,messages,models,peer_handlers,peer_node,route_handlers,storage_providers,test,wallet_manager}/**/*.test.ts\" \"p2p/test/test*.js\"",
    "test:integration": "tsx --test --test-timeout=300000 \"test/integration/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-glacier": "^3.1010.0",
    "@aws-sdk/client-s3": "^3.1010.0",
    "@aws-sdk/lib-storage": "^3.1010.0",
    "@subspace/reed-solomon-erasure.wasm": "^0.2.5",
    "archiver": "^7.0.1",
    "bufferutil": "^4.0.6",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "glob": "^13.0.6",
    "mongodb": "^7.1.0",
    "multer": "^2.1.1",
    "node-fetch": "^2.7.0",
    "smb2": "^0.2.11",
    "ssh2": "^1.17.0",
    "ssh2-sftp-client": "^12.1.0",
    "unzipper": "^0.12.3",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/node-fetch": "^2.6.13",
    "@types/smb2": "^0.2.4",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@types/unzipper": "^0.10.11",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "form-data": "^4.0.5",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3"
  }
}
